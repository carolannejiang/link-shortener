# Copy this file to .env.local and fill in the values for local development.
# In production, Vercel sets the Redis values automatically when you connect a
# Redis database, and you add ADMIN_PASSWORD yourself in Project Settings.

# A long password you choose. The only thing protecting your links.
ADMIN_PASSWORD=

# From Vercel Storage → your Redis database → ".env.local" tab. Copy both.
# (Some providers name these UPSTASH_REDIS_REST_URL / _TOKEN — either works.)
KV_REST_API_URL=
KV_REST_API_TOKEN=
